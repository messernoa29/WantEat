# App
ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_USER=wanteat
POSTGRES_PASSWORD=wanteat_secret
POSTGRES_DB=wanteat_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wanteat:wanteat_secret@postgres:5432/wanteat_db

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# External APIs
ANTHROPIC_API_KEY=sk-ant-...
SPOONACULAR_API_KEY=your-key
OPEN_FOOD_FACTS_APP_NAME=wanteat-dev

# Frontend
VITE_API_BASE_URL=http://localhost:8001/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
